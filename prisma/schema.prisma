generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// AUTH & USER MANAGEMENT
// ============================================

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique @db.VarChar(255)
  password_hash String   @db.VarChar(255)
  full_name     String   @db.VarChar(255)
  phone         String?  @db.VarChar(20)
  role          UserRole @default(sale)
  avatar_url    String?  @db.VarChar(500)
  is_active     Boolean  @default(true)
  createdAt     DateTime @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  assignedLeads  Lead[]         @relation("LeadAssignee")
  leadActivities LeadActivity[]
  student        Student?
  teacher        Teacher?
  createdPayments Payment[]     @relation("PaymentCreator")

  @@index([role])
  @@index([is_active])
  @@map("users")
}

// ============================================
// CRM / LEAD MANAGEMENT
// ============================================

model Lead {
  id                Int         @id @default(autoincrement())
  full_name         String      @db.VarChar(255)
  phone             String?     @db.VarChar(20)
  email             String?     @db.VarChar(255)
  source            LeadSource  @default(other)
  status            LeadStatus  @default(new)
  ai_score          Float?
  ai_recommendation String?     @db.Text
  assigned_to       Int?
  notes             String?     @db.Text
  last_contacted    DateTime?   @db.Timestamptz(6)
  createdAt         DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime    @updatedAt @db.Timestamptz(6)

  // Relations
  assignedUser User?          @relation("LeadAssignee", fields: [assigned_to], references: [id], onDelete: SetNull)
  activities   LeadActivity[]
  student      Student?

  @@index([status])
  @@index([source])
  @@index([assigned_to])
  @@index([createdAt])
  @@map("leads")
}

model LeadActivity {
  id        Int              @id @default(autoincrement())
  lead_id   Int
  user_id   Int?
  type      LeadActivityType
  content   String?          @db.Text
  createdAt DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt DateTime         @updatedAt @db.Timestamptz(6)

  // Relations
  lead Lead  @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  user User? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([lead_id])
  @@index([user_id])
  @@index([type])
  @@map("lead_activities")
}

// ============================================
// STUDENT MANAGEMENT
// ============================================

model Student {
  id                 Int               @id @default(autoincrement())
  user_id            Int?              @unique
  lead_id            Int?              @unique
  full_name          String            @db.VarChar(255)
  phone              String?           @db.VarChar(20)
  email              String?           @unique @db.VarChar(255)
  dob                DateTime?         @db.Date
  status             StudentStatus     @default(active)
  enrollment_date    DateTime?         @db.Date
  dropout_risk       Float?
  dropout_risk_level DropoutRiskLevel?
  createdAt          DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime          @updatedAt @db.Timestamptz(6)

  // Relations
  user             User?              @relation(fields: [user_id], references: [id], onDelete: SetNull)
  lead             Lead?              @relation(fields: [lead_id], references: [id], onDelete: SetNull)
  classEnrollments ClassEnrollment[]
  attendances      Attendance[]
  testResults      TestResult[]
  payments         Payment[]

  @@index([status])
  @@index([enrollment_date])
  @@map("students")
}

// ============================================
// TEACHER MANAGEMENT
// ============================================

model Teacher {
  id             Int         @id @default(autoincrement())
  user_id        Int?        @unique
  full_name      String      @db.VarChar(255)
  phone          String?     @db.VarChar(20)
  email          String?     @unique @db.VarChar(255)
  type           TeacherType @default(full_time)
  specialization String?     @db.VarChar(255)
  is_active      Boolean     @default(true)
  createdAt      DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime    @updatedAt @db.Timestamptz(6)

  // Relations
  user      User?      @relation(fields: [user_id], references: [id], onDelete: SetNull)
  classes   Class[]
  schedules Schedule[]

  @@index([is_active])
  @@map("teachers")
}

// ============================================
// COURSE & CLASS MANAGEMENT
// ============================================

model Course {
  id             Int      @id @default(autoincrement())
  name           String   @db.VarChar(255)
  description    String?  @db.Text
  total_sessions Int?
  fee            Decimal? @db.Decimal(15, 2)
  duration_weeks Int?
  createdAt      DateTime @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  classes Class[]

  @@map("courses")
}

model Class {
  id            Int          @id @default(autoincrement())
  name          String       @db.VarChar(255)
  course_id     Int?
  teacher_id    Int?
  room_id       Int?
  status        ClassStatus  @default(upcoming)
  start_date    DateTime?    @db.Date
  end_date      DateTime?    @db.Date
  schedule_days String?      @db.VarChar(255)
  schedule_time String?      @db.VarChar(255)
  max_students  Int?
  createdAt     DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime     @updatedAt @db.Timestamptz(6)

  // Relations
  course           Course?           @relation(fields: [course_id], references: [id], onDelete: SetNull)
  teacher          Teacher?          @relation(fields: [teacher_id], references: [id], onDelete: SetNull)
  room             Room?             @relation(fields: [room_id], references: [id], onDelete: SetNull)
  classEnrollments ClassEnrollment[]
  schedules        Schedule[]
  tests            Test[]
  payments         Payment[]

  @@index([status])
  @@index([course_id])
  @@index([teacher_id])
  @@index([room_id])
  @@map("classes")
}

model ClassEnrollment {
  id         Int              @id @default(autoincrement())
  class_id   Int
  student_id Int
  status     EnrollmentStatus @default(active)
  createdAt  DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime         @updatedAt @db.Timestamptz(6)

  // Relations
  class   Class   @relation(fields: [class_id], references: [id], onDelete: Cascade)
  student Student @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([class_id, student_id])
  @@index([student_id])
  @@map("class_enrollments")
}

// ============================================
// SCHEDULING & ATTENDANCE
// ============================================

model Room {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(255)
  capacity  Int?
  equipment String?  @db.Text
  is_active Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  classes   Class[]
  schedules Schedule[]

  @@map("rooms")
}

model Schedule {
  id         Int            @id @default(autoincrement())
  class_id   Int?
  teacher_id Int?
  room_id    Int?
  date       DateTime       @db.Date
  start_time DateTime?      @db.Time(6)
  end_time   DateTime?      @db.Time(6)
  status     ScheduleStatus @default(scheduled)
  notes      String?        @db.Text
  createdAt  DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime       @updatedAt @db.Timestamptz(6)

  // Relations
  class       Class?       @relation(fields: [class_id], references: [id], onDelete: Cascade)
  teacher     Teacher?     @relation(fields: [teacher_id], references: [id], onDelete: SetNull)
  room        Room?        @relation(fields: [room_id], references: [id], onDelete: SetNull)
  attendances Attendance[]

  @@index([date])
  @@index([class_id])
  @@index([teacher_id])
  @@index([room_id])
  @@map("schedules")
}

model Attendance {
  id          Int              @id @default(autoincrement())
  schedule_id Int
  student_id  Int
  status      AttendanceStatus @default(present)
  notes       String?          @db.Text
  createdAt   DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime         @updatedAt @db.Timestamptz(6)

  // Relations
  schedule Schedule @relation(fields: [schedule_id], references: [id], onDelete: Cascade)
  student  Student  @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([schedule_id, student_id])
  @@index([student_id])
  @@map("attendances")
}

// ============================================
// ASSESSMENT
// ============================================

model Test {
  id        Int      @id @default(autoincrement())
  class_id  Int
  name      String   @db.VarChar(255)
  type      TestType
  max_score Float?
  test_date DateTime? @db.Date
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)

  // Relations
  class       Class        @relation(fields: [class_id], references: [id], onDelete: Cascade)
  testResults TestResult[]

  @@index([class_id])
  @@index([test_date])
  @@map("tests")
}

model TestResult {
  id         Int      @id @default(autoincrement())
  test_id    Int
  student_id Int
  score      Float?
  feedback   String?  @db.Text
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  test    Test    @relation(fields: [test_id], references: [id], onDelete: Cascade)
  student Student @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([test_id, student_id])
  @@index([student_id])
  @@map("test_results")
}

// ============================================
// FINANCE
// ============================================

model Payment {
  id           Int           @id @default(autoincrement())
  student_id   Int
  class_id     Int?
  amount       Decimal       @db.Decimal(15, 2)
  payment_date DateTime?     @db.Date
  method       PaymentMethod @default(cash)
  status       PaymentStatus @default(pending)
  notes        String?       @db.Text
  created_by   Int?
  createdAt    DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @db.Timestamptz(6)

  // Relations
  student Student @relation(fields: [student_id], references: [id], onDelete: Cascade)
  class   Class?  @relation(fields: [class_id], references: [id], onDelete: SetNull)
  creator User?   @relation("PaymentCreator", fields: [created_by], references: [id], onDelete: SetNull)

  @@index([student_id])
  @@index([class_id])
  @@index([status])
  @@index([payment_date])
  @@map("payments")
}

// ============================================
// AI PREDICTIONS
// ============================================

model AIPrediction {
  id              Int            @id @default(autoincrement())
  prediction_type PredictionType
  reference_id    Int?
  input_data      Json?
  result_data     Json?
  createdAt       DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @db.Timestamptz(6)

  @@index([prediction_type])
  @@index([reference_id])
  @@map("ai_predictions")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  admin
  sale
  teacher
  student
}

enum LeadSource {
  facebook
  zalo
  website
  referral
  walk_in
  other
}

enum LeadStatus {
  new
  contacted
  interested
  trial
  enrolled
  lost
}

enum LeadActivityType {
  call
  email
  sms
  meeting
  note
  status_change
}

enum StudentStatus {
  active
  inactive
  graduated
  dropped
}

enum DropoutRiskLevel {
  low
  medium
  high
}

enum TeacherType {
  full_time
  part_time
}

enum ClassStatus {
  upcoming
  ongoing
  completed
  cancelled
}

enum EnrollmentStatus {
  active
  dropped
  completed
}

enum ScheduleStatus {
  scheduled
  completed
  cancelled
}

enum AttendanceStatus {
  present
  absent
  late
  excused
}

enum TestType {
  quiz
  midterm
  final
  assignment
}

enum PaymentMethod {
  cash
  bank_transfer
  momo
  vnpay
  other
}

enum PaymentStatus {
  pending
  paid
  refunded
}

enum PredictionType {
  lead_score
  dropout_risk
  revenue_forecast
}
