generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SequelizeMeta {
  name String @id @db.VarChar(255)
}

model AIPredictions {
  id              Int                                @id @default(autoincrement())
  prediction_type enum_AIPredictions_prediction_type
  reference_id    Int?
  input_data      Json?
  result_data     Json?
  createdAt       DateTime                           @db.Timestamptz(6)
  updatedAt       DateTime                           @db.Timestamptz(6)
}

model Attendances {
  id          Int                     @id @default(autoincrement())
  schedule_id Int
  student_id  Int
  status      enum_Attendances_status @default(present)
  notes       String?
  createdAt   DateTime                @db.Timestamptz(6)
  updatedAt   DateTime                @db.Timestamptz(6)
  Schedules   Schedules               @relation(fields: [schedule_id], references: [id], onDelete: Cascade)
  Students    Students                @relation(fields: [student_id], references: [id], onDelete: Cascade)
}

model ClassEnrollments {
  id         Int                           @id @default(autoincrement())
  class_id   Int
  student_id Int
  status     enum_ClassEnrollments_status? @default(active)
  createdAt  DateTime                      @db.Timestamptz(6)
  updatedAt  DateTime                      @db.Timestamptz(6)
  Classes    Classes                       @relation(fields: [class_id], references: [id], onDelete: Cascade)
  Students   Students                      @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([class_id, student_id])
}

model Classes {
  id               Int                  @id @default(autoincrement())
  name             String               @db.VarChar(255)
  course_id        Int?
  teacher_id       Int?
  room_id          Int?
  status           enum_Classes_status? @default(upcoming)
  start_date       DateTime?            @db.Date
  end_date         DateTime?            @db.Date
  schedule_days    String?              @db.VarChar(255)
  schedule_time    String?              @db.VarChar(255)
  max_students     Int?
  createdAt        DateTime             @db.Timestamptz(6)
  updatedAt        DateTime             @db.Timestamptz(6)
  ClassEnrollments ClassEnrollments[]
  Courses          Courses?             @relation(fields: [course_id], references: [id], onDelete: Cascade)
  Rooms            Rooms?               @relation(fields: [room_id], references: [id], onDelete: Cascade)
  Teachers         Teachers?            @relation(fields: [teacher_id], references: [id], onDelete: Cascade)
  Payments         Payments[]
  Schedules        Schedules[]
  Tests            Tests[]
}

model Courses {
  id             Int       @id @default(autoincrement())
  name           String    @db.VarChar(255)
  description    String?
  total_sessions Int?
  fee            Decimal?  @db.Decimal(15, 2)
  duration_weeks Int?
  createdAt      DateTime  @db.Timestamptz(6)
  updatedAt      DateTime  @db.Timestamptz(6)
  Classes        Classes[]
}

model LeadActivities {
  id        Int                      @id @default(autoincrement())
  lead_id   Int
  user_id   Int?
  type      enum_LeadActivities_type
  content   String?
  createdAt DateTime                 @db.Timestamptz(6)
  updatedAt DateTime                 @db.Timestamptz(6)
  Leads     Leads                    @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  Users     Users?                   @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Leads {
  id                Int                @id @default(autoincrement())
  full_name         String             @db.VarChar(255)
  phone             String?            @db.VarChar(255)
  email             String?            @db.VarChar(255)
  source            enum_Leads_source? @default(other)
  status            enum_Leads_status? @default(new)
  ai_score          Float?
  ai_recommendation String?
  assigned_to       Int?
  notes             String?
  last_contacted    DateTime?          @db.Timestamptz(6)
  createdAt         DateTime           @db.Timestamptz(6)
  updatedAt         DateTime           @db.Timestamptz(6)
  LeadActivities    LeadActivities[]
  Users             Users?             @relation(fields: [assigned_to], references: [id], onDelete: Cascade)
  Students          Students[]
}

model Payments {
  id           Int                   @id @default(autoincrement())
  student_id   Int
  class_id     Int?
  amount       Decimal               @db.Decimal(15, 2)
  payment_date DateTime?             @db.Date
  method       enum_Payments_method? @default(cash)
  status       enum_Payments_status? @default(pending)
  notes        String?
  created_by   Int?
  createdAt    DateTime              @db.Timestamptz(6)
  updatedAt    DateTime              @db.Timestamptz(6)
  Classes      Classes?              @relation(fields: [class_id], references: [id], onDelete: Cascade)
  Users        Users?                @relation(fields: [created_by], references: [id], onDelete: Cascade)
  Students     Students              @relation(fields: [student_id], references: [id], onDelete: Cascade)
}

model Rooms {
  id        Int         @id @default(autoincrement())
  name      String      @db.VarChar(255)
  capacity  Int?
  equipment String?
  is_active Boolean?    @default(true)
  createdAt DateTime    @db.Timestamptz(6)
  updatedAt DateTime    @db.Timestamptz(6)
  Classes   Classes[]
  Schedules Schedules[]
}

model Schedules {
  id          Int                    @id @default(autoincrement())
  class_id    Int?
  teacher_id  Int?
  room_id     Int?
  date        DateTime               @db.Date
  start_time  DateTime?              @db.Time(6)
  end_time    DateTime?              @db.Time(6)
  status      enum_Schedules_status? @default(scheduled)
  notes       String?
  createdAt   DateTime               @db.Timestamptz(6)
  updatedAt   DateTime               @db.Timestamptz(6)
  Attendances Attendances[]
  Classes     Classes?               @relation(fields: [class_id], references: [id], onDelete: Cascade)
  Rooms       Rooms?                 @relation(fields: [room_id], references: [id], onDelete: Cascade)
  Teachers    Teachers?              @relation(fields: [teacher_id], references: [id], onDelete: Cascade)
}

model Students {
  id                 Int                               @id @default(autoincrement())
  user_id            Int?
  lead_id            Int?
  full_name          String                            @db.VarChar(255)
  phone              String?                           @db.VarChar(255)
  email              String?                           @db.VarChar(255)
  dob                DateTime?                         @db.Date
  status             enum_Students_status?             @default(active)
  enrollment_date    DateTime?                         @db.Date
  dropout_risk       Float?
  dropout_risk_level enum_Students_dropout_risk_level?
  createdAt          DateTime                          @db.Timestamptz(6)
  updatedAt          DateTime                          @db.Timestamptz(6)
  Attendances        Attendances[]
  ClassEnrollments   ClassEnrollments[]
  Payments           Payments[]
  Leads              Leads?                            @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  Users              Users?                            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  TestResults        TestResults[]
}

model Teachers {
  id             Int                 @id @default(autoincrement())
  user_id        Int?
  full_name      String              @db.VarChar(255)
  phone          String?             @db.VarChar(255)
  email          String?             @db.VarChar(255)
  type           enum_Teachers_type? @default(full_time)
  specialization String?             @db.VarChar(255)
  is_active      Boolean?            @default(true)
  createdAt      DateTime            @db.Timestamptz(6)
  updatedAt      DateTime            @db.Timestamptz(6)
  Classes        Classes[]
  Schedules      Schedules[]
  Users          Users?              @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model TestResults {
  id         Int      @id @default(autoincrement())
  test_id    Int
  student_id Int
  score      Float?
  feedback   String?
  createdAt  DateTime @db.Timestamptz(6)
  updatedAt  DateTime @db.Timestamptz(6)
  Students   Students @relation(fields: [student_id], references: [id], onDelete: Cascade)
  Tests      Tests    @relation(fields: [test_id], references: [id], onDelete: Cascade)
}

model Tests {
  id          Int             @id @default(autoincrement())
  class_id    Int
  name        String          @db.VarChar(255)
  type        enum_Tests_type
  max_score   Float?
  test_date   DateTime?       @db.Date
  createdAt   DateTime        @db.Timestamptz(6)
  updatedAt   DateTime        @db.Timestamptz(6)
  TestResults TestResults[]
  Classes     Classes         @relation(fields: [class_id], references: [id], onDelete: Cascade)
}

model Users {
  id             Int              @id @default(autoincrement())
  email          String           @unique @db.VarChar(255)
  password_hash  String           @db.VarChar(255)
  full_name      String           @db.VarChar(255)
  phone          String?          @db.VarChar(255)
  role           enum_Users_role  @default(staff)
  avatar_url     String?          @db.VarChar(255)
  is_active      Boolean?         @default(true)
  createdAt      DateTime         @db.Timestamptz(6)
  updatedAt      DateTime         @db.Timestamptz(6)
  LeadActivities LeadActivities[]
  Leads          Leads[]
  Payments       Payments[]
  Students       Students[]
  Teachers       Teachers[]
}

enum enum_AIPredictions_prediction_type {
  lead_score
  dropout_risk
  revenue_forecast
}

enum enum_Attendances_status {
  present
  absent
  late
  excused
}

enum enum_ClassEnrollments_status {
  active
  dropped
  completed
}

enum enum_Classes_status {
  upcoming
  ongoing
  completed
  cancelled
}

enum enum_LeadActivities_type {
  call
  email
  sms
  meeting
  note
  status_change
}

enum enum_Leads_source {
  facebook
  zalo
  website
  referral
  walk_in
  other
}

enum enum_Leads_status {
  new
  contacted
  interested
  trial
  enrolled
  lost
}

enum enum_Payments_method {
  cash
  bank_transfer
  momo
  vnpay
  other
}

enum enum_Payments_status {
  pending
  paid
  refunded
}

enum enum_Schedules_status {
  scheduled
  completed
  cancelled
}

enum enum_Students_dropout_risk_level {
  low
  medium
  high
}

enum enum_Students_status {
  active
  inactive
  graduated
  dropped
}

enum enum_Teachers_type {
  full_time
  part_time
}

enum enum_Tests_type {
  quiz
  midterm
  final
  assignment
}

enum enum_Users_role {
  admin
  staff
  teacher
}
