# EduCRM Microservices Environment Configuration

# ==========================================
# DEVELOPMENT ENVIRONMENT
# ==========================================

# Database Configuration (PostgreSQL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=educrm
POSTGRES_PASSWORD=password

# Service-specific Database URLs
AUTH_DATABASE_URL=postgresql://educrm:password@localhost:5432/educrm_auth
LMS_DATABASE_URL=postgresql://educrm:password@localhost:5432/educrm_lms
CRM_DATABASE_URL=postgresql://educrm:password@localhost:5432/educrm_crm
FINANCE_DATABASE_URL=postgresql://educrm:password@localhost:5432/educrm_finance
AI_DATABASE_URL=postgresql://educrm:password@localhost:5432/educrm_ai
NOTIFICATION_DATABASE_URL=postgresql://educrm:password@localhost:5432/educrm_notifications

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Service URLs (for inter-service communication)
AUTH_SERVICE_URL=http://localhost:3001
LMS_SERVICE_URL=http://localhost:3002
CRM_SERVICE_URL=http://localhost:3003
FINANCE_SERVICE_URL=http://localhost:3004
AI_SERVICE_URL=http://localhost:3005
NOTIFICATION_SERVICE_URL=http://localhost:3006

# ==========================================
# PRODUCTION ENVIRONMENT (AWS Example)
# ==========================================

# AWS RDS PostgreSQL
# PROD_POSTGRES_HOST=educrm-db.cluster-xyz.us-east-1.rds.amazonaws.com
# PROD_POSTGRES_PORT=5432
# PROD_POSTGRES_USER=educrm_prod_user
# PROD_POSTGRES_PASSWORD=your-secure-password

# AWS ElastiCache Redis
# PROD_REDIS_URL=redis://educrm-cache.xxx.clustercfg.ap-southeast-1.cache.amazonaws.com:6379

# Production JWT (use strong secret)
# PROD_JWT_SECRET=your-production-jwt-secret-key-minimum-256-bits

# ==========================================
# THIRD-PARTY SERVICES
# ==========================================

# Email Configuration (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Payment Gateway (Stripe)
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Payment Gateway (PayPal)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# ==========================================
# MONITORING & LOGGING
# ==========================================

# Application Environment
NODE_ENV=development

# Logging Level
LOG_LEVEL=info

# Health Check
HEALTH_CHECK_INTERVAL=30000

# ==========================================
# SECURITY
# ==========================================

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# FILE UPLOAD
# ==========================================

# AWS S3 Configuration (for file uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=educrm-uploads

# Local Upload Path (development)
UPLOAD_PATH=./uploads

# ==========================================
# AI/ML CONFIGURATION
# ==========================================

# AI Model Endpoints
AI_MODEL_ENDPOINT=http://localhost:5000
AI_PREDICTION_THRESHOLD=0.8

# Machine Learning
ML_MODEL_PATH=./models
ML_TRAINING_DATA_PATH=./data/training

# ==========================================
# NOTIFICATION TEMPLATES
# ==========================================

# Email Templates Path
EMAIL_TEMPLATES_PATH=./templates/email

# SMS Templates
SMS_WELCOME_TEMPLATE="Welcome to EduCRM, {{name}}!"
SMS_PAYMENT_REMINDER="Payment due for {{amount}} VND on {{due_date}}"

# ==========================================
# BACKUP & MAINTENANCE
# ==========================================

# Database Backup
DB_BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
DB_BACKUP_RETENTION_DAYS=30

# Cache Configuration
REDIS_CACHE_TTL=3600  # 1 hour
REDIS_MAX_MEMORY=256mb

# ==========================================
# DEVELOPMENT TOOLS
# ==========================================

# Database Management (pgAdmin)
PGADMIN_DEFAULT_EMAIL=admin@educrm.com
PGADMIN_DEFAULT_PASSWORD=admin123

# Redis Management
REDIS_COMMANDER_HOST=localhost
REDIS_COMMANDER_PORT=8081